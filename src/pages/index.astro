</style>

<script>
  // --- Constellation Animation ---
  const canvas = document.getElementById('constellation') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  let animId: number;
  const stars: { x: number; y: number; vx: number; vy: number; r: number; opacity: number }[] = [];
  const STAR_COUNT = 80;
  const CONNECT_DIST = 150;

  function resize() {
    const hero = canvas.parentElement!;
    canvas.width = hero.offsetWidth;
    canvas.height = hero.offsetHeight;
  }

  function initStars() {
    stars.length = 0;
    for (let i = 0; i < STAR_COUNT; i++) {
      stars.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        r: Math.random() * 1.5 + 0.5,
        opacity: Math.random() * 0.5 + 0.3,
      });
    }
  }

  function drawStars() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Draw connections
    for (let i = 0; i < stars.length; i++) {
      for (let j = i + 1; j < stars.length; j++) {
        const dx = stars[i].x - stars[j].x;
        const dy = stars[i].y - stars[j].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < CONNECT_DIST) {
          const alpha = (1 - dist / CONNECT_DIST) * 0.15;
          ctx.strokeStyle = `rgba(59, 130, 246, ${alpha})`;
          ctx.lineWidth = 0.5;
          ctx.beginPath();
          ctx.moveTo(stars[i].x, stars[i].y);
          ctx.lineTo(stars[j].x, stars[j].y);
          ctx.stroke();
        }
      }
    }

    // Draw stars
    for (const s of stars) {
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(139, 92, 246, ${s.opacity})`;
      ctx.fill();

      // Move
      s.x += s.vx;
      s.y += s.vy;

      // Wrap around
      if (s.x < 0) s.x = canvas.width;
      if (s.x > canvas.width) s.x = 0;
      if (s.y < 0) s.y = canvas.height;
      if (s.y > canvas.height) s.y = 0;
    }

    animId = requestAnimationFrame(drawStars);
  }

  resize();
  initStars();
  drawStars();
  window.addEventListener('resize', () => { resize(); initStars(); });

  // --- Typing Effect ---
  const codeLines = [
    { text: '# Install the platform', type: 'comment' },
    { text: 'helm repo add omnia https://charts.altairalabs.ai', type: 'cmd' },
    { text: 'helm install omnia omnia/omnia -n omnia-system --create-namespace', type: 'cmd' },
    { text: '', type: 'blank' },
    { text: '# Deploy an agent — any framework, any model', type: 'comment' },
    { text: 'kubectl apply -f my-agent.yaml', type: 'cmd' },
    { text: '', type: 'blank' },
    { text: '# Scale it. K8s handles the rest.', type: 'comment' },
    { text: 'kubectl scale agentruntime my-agent --replicas=20', type: 'cmd' },
  ];

  const codeEl = document.getElementById('typed-code')!;
  let lineIdx = 0;
  let charIdx = 0;
  let currentHTML = '';

  function typeNext() {
    if (lineIdx >= codeLines.length) return;

    const line = codeLines[lineIdx];

    if (line.type === 'blank') {
      currentHTML += '\n';
      codeEl.innerHTML = currentHTML;
      lineIdx++;
      charIdx = 0;
      setTimeout(typeNext, 150);
      return;
    }

    if (charIdx === 0 && line.type === 'comment') {
      currentHTML += '<span class="code-comment">';
    }

    if (charIdx < line.text.length) {
      currentHTML += line.text[charIdx];
      codeEl.innerHTML = currentHTML + (line.type === 'comment' ? '</span>' : '');
      charIdx++;
      setTimeout(typeNext, line.type === 'comment' ? 20 : 25);
    } else {
      if (line.type === 'comment') {
        currentHTML += '</span>';
      }
      currentHTML += '\n';
      codeEl.innerHTML = currentHTML;
      lineIdx++;
      charIdx = 0;
      setTimeout(typeNext, 300);
    }
  }

  // Start typing after a short delay
  setTimeout(typeNext, 800);

  // --- Scroll Reveal ---
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  reveals.forEach((el) => observer.observe(el));

  // --- Table row animation ---
  const table = document.querySelector('.comparison-table');
  if (table) {
    const tableObserver = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          table.classList.add('in-view');
          tableObserver.unobserve(table);
        }
      },
      { threshold: 0.2 }
    );
    tableObserver.observe(table);
  }
</script>
