---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;
const siteUrl = import.meta.env.SITE ?? 'https://altairalabs.github.io';
const canonicalUrl = `${siteUrl}${base}/blog/${post.id}/`;
const ogImage = `${siteUrl}${base}/og/${post.id}.png`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  dateModified: (post.data.updated ?? post.data.date).toISOString(),
  author: {
    '@type': 'Organization',
    name: post.data.author,
    url: 'https://altairalabs.github.io/altairalabs-web/',
  },
  publisher: {
    '@type': 'Organization',
    name: 'AltairaLabs',
  },
};
---

<BaseLayout title={`${post.data.title} - AltairaLabs`} description={post.data.description} image={post.data.image ?? ogImage} canonicalUrl={canonicalUrl}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <section class="post-hero">
    <div class="container">
      <a href={`${base}/blog/`} class="back-link">&larr; Back to Blog</a>
    </div>
  </section>

  <article class="post-article">
    <div class="post-container">
      <header class="post-header">
        <h1>{post.data.title}</h1>
        <div class="post-meta">
          <span class="post-author">{post.data.author}</span>
          <span class="meta-sep">&middot;</span>
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {post.data.updated && (
            <>
              <span class="meta-sep">&middot;</span>
              <span class="post-updated">
                Updated {post.data.updated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
            </>
          )}
        </div>
        {post.data.tags && (
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
        <div class="share-bar">
          <button class="share-copy" id="copy-link" data-url={canonicalUrl}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
            <span class="share-copy-text">Copy link</span>
          </button>
          <button class="share-native" id="share-native" style="display:none;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
              <polyline points="16 6 12 2 8 6"/>
              <line x1="12" y1="2" x2="12" y2="15"/>
            </svg>
            Share
          </button>
        </div>
      </header>

      <div class="post-content">
        <Content />
      </div>

      <footer class="post-footer">
        <div class="post-footer-row">
          <a href={`${base}/blog/`} class="back-link">&larr; Back to Blog</a>
          <button class="share-copy" id="copy-link-footer" data-url={canonicalUrl}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
            <span class="share-copy-text">Copy link</span>
          </button>
        </div>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .post-hero {
    background: var(--gradient-dark);
    padding: calc(72px + var(--space-xl)) 0 var(--space-xl);
  }

  .post-hero .back-link {
    color: var(--slate);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .post-hero .back-link:hover {
    color: white;
  }

  .post-article {
    padding: var(--space-3xl) 0 var(--space-4xl);
  }

  .post-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .post-header {
    margin-bottom: var(--space-3xl);
  }

  .post-header h1 {
    font-size: 2.5rem;
    margin-bottom: var(--space-md);
    color: var(--deep-space);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.875rem;
    color: var(--slate);
    margin-bottom: var(--space-md);
  }

  .post-author {
    font-weight: 600;
  }

  .meta-sep {
    color: var(--mist);
  }

  .post-updated {
    font-style: italic;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tag {
    display: inline-block;
    padding: 2px 10px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--altair-blue);
    background: rgba(59, 130, 246, 0.1);
    border-radius: var(--radius-full);
    text-transform: lowercase;
  }

  .post-content {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--onyx);
  }

  .post-content :global(h2) {
    font-size: 1.75rem;
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-md);
  }

  .post-content :global(h3) {
    font-size: 1.375rem;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .post-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .post-content :global(a) {
    color: var(--altair-blue);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-content :global(a:hover) {
    color: var(--altair-blue-dark);
  }

  .post-content :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875em;
    background: rgba(59, 130, 246, 0.08);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }

  .post-content :global(pre) {
    background: var(--deep-space);
    color: var(--mist);
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--altair-blue);
    padding-left: var(--space-lg);
    margin: 1.5rem 0;
    color: var(--slate);
    font-style: italic;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(img) {
    max-width: 100%;
    border-radius: var(--radius-md);
    margin: 1.5rem 0;
  }

  .share-bar {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .share-copy,
  .share-native {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    font-size: 0.8125rem;
    font-weight: 500;
    font-family: inherit;
    color: var(--slate);
    background: transparent;
    border: 1px solid var(--mist);
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .share-copy:hover,
  .share-native:hover {
    color: var(--altair-blue);
    border-color: var(--altair-blue);
  }

  .share-copy.copied {
    color: var(--deploy-green);
    border-color: var(--deploy-green);
  }

  .post-footer {
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--mist);
  }

  .post-footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .back-link {
    color: var(--altair-blue);
    font-weight: 500;
    font-size: 0.9375rem;
  }

  .back-link:hover {
    color: var(--altair-blue-dark);
  }

  @media (max-width: 768px) {
    .post-header h1 {
      font-size: 1.75rem;
    }

    .post-content {
      font-size: 1rem;
      line-height: 1.7;
    }

    .post-content :global(h2) {
      font-size: 1.375rem;
      margin-top: var(--space-2xl);
    }

    .post-content :global(h3) {
      font-size: 1.125rem;
      margin-top: var(--space-xl);
    }

    .post-meta {
      flex-wrap: wrap;
    }

    .post-content :global(blockquote) {
      padding-left: var(--space-md);
    }

    .post-content :global(pre) {
      padding: var(--space-md);
    }

    .post-content :global(pre code) {
      font-size: 0.8125rem;
    }
  }

  @media (max-width: 480px) {
    .post-header h1 {
      font-size: 1.5rem;
    }

    .post-content :global(h2) {
      font-size: 1.25rem;
    }

    .post-content :global(h3) {
      font-size: 1.0625rem;
    }
  }
</style>

<script>
  // Copy link buttons
  document.querySelectorAll<HTMLButtonElement>('.share-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url || window.location.href;
      await navigator.clipboard.writeText(url);
      const textEl = btn.querySelector('.share-copy-text')!;
      const original = textEl.textContent;
      textEl.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => {
        textEl.textContent = original;
        btn.classList.remove('copied');
      }, 2000);
    });
  });

  // Native share (mobile)
  const shareBtn = document.getElementById('share-native') as HTMLButtonElement;
  if (navigator.share) {
    shareBtn.style.display = '';
    shareBtn.addEventListener('click', () => {
      const title = document.querySelector<HTMLHeadingElement>('.post-header h1')?.textContent || '';
      navigator.share({
        title,
        url: window.location.href,
      });
    });
  }
</script>
