---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="logo">
          <svg class="logo-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="20" cy="6" r="3" fill="#3B82F6"/>
            <circle cx="8" cy="18" r="2.5" fill="#06B6D4"/>
            <circle cx="32" cy="18" r="2.5" fill="#06B6D4"/>
            <circle cx="12" cy="32" r="2" fill="#8B5CF6"/>
            <circle cx="28" cy="32" r="2" fill="#8B5CF6"/>
            <circle cx="20" cy="20" r="3" fill="#3B82F6"/>
            <line x1="20" y1="9" x2="20" y2="17" stroke="#3B82F6" stroke-width="1.5"/>
            <line x1="10" y1="18" x2="17" y2="20" stroke="#06B6D4" stroke-width="1.5"/>
            <line x1="30" y1="18" x2="23" y2="20" stroke="#06B6D4" stroke-width="1.5"/>
            <line x1="13" y1="31" x2="18" y2="22" stroke="#8B5CF6" stroke-width="1.5"/>
            <line x1="27" y1="31" x2="22" y2="22" stroke="#8B5CF6" stroke-width="1.5"/>
          </svg>
          <span class="logo-text">ALTAIRA<span class="logo-labs">LABS</span></span>
        </a>
        <p class="footer-tagline">Kubernetes-Native AgentOps</p>
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <p class="footer-heading">Products</p>
          <a href="https://omnia.altairalabs.ai/" target="_blank" rel="noopener">Omnia Platform</a>
          <a href="https://promptkit.altairalabs.ai/" target="_blank" rel="noopener">PromptKit</a>
          <a href="https://github.com/AltairaLabs/promptarena-deploy-agentcore" target="_blank" rel="noopener">PromptArena</a>
          <a href="https://promptpack.org/" target="_blank" rel="noopener">PromptPack</a>
        </div>
        <div class="footer-col">
          <p class="footer-heading">Documentation</p>
          <a href="https://omnia.altairalabs.ai/" target="_blank" rel="noopener">Omnia Docs</a>
          <a href="https://promptkit.altairalabs.ai/" target="_blank" rel="noopener">PromptKit Docs</a>
          <a href="https://promptpack.org/" target="_blank" rel="noopener">PromptPack Spec</a>
          <a href="https://github.com/AltairaLabs/promptpack-python" target="_blank" rel="noopener">PromptPack Python SDK</a>
          <a href="https://github.com/AltairaLabs/promptpack-langchainjs" target="_blank" rel="noopener">PromptPack LangChain.js</a>
        </div>
        <div class="footer-col">
          <p class="footer-heading">Community</p>
          <a href="https://github.com/AltairaLabs" target="_blank" rel="noopener">GitHub</a>
          <a href="https://github.com/AltairaLabs/Omnia" target="_blank" rel="noopener">Omnia Repo</a>
          <a href="https://github.com/AltairaLabs/PromptKit" target="_blank" rel="noopener">PromptKit Repo</a>
          <a href="https://github.com/AltairaLabs/promptpack-spec" target="_blank" rel="noopener">PromptPack Repo</a>
          <a href="mailto:hello@altairalabs.ai">hello@altairalabs.ai</a>
          <a href="https://calendly.com/charlie-holland-activeware/altairalabs-how-can-i-help" target="_blank" rel="noopener">Book a Call</a>
          <a href="https://www.linkedin.com/in/chaholl/" target="_blank" rel="noopener">LinkedIn</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {currentYear} AltairaLabs. All rights reserved.</p>
      <div class="footer-legal">
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-3xl) 0 var(--space-xl);
    background: var(--deep-space);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 2fr;
    gap: var(--space-3xl);
    margin-bottom: var(--space-2xl);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
  }

  .logo-icon {
    width: 36px;
    height: 36px;
  }

  .logo-text {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: white;
  }

  .logo-labs {
    font-weight: 400;
    letter-spacing: 0.2em;
    color: var(--slate);
    margin-left: 4px;
  }

  .footer-tagline {
    color: var(--slate);
    margin-top: var(--space-md);
    margin-bottom: 0;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .footer-heading {
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  .footer-col a {
    display: block;
    color: var(--slate);
    font-size: 0.9375rem;
    padding: var(--space-xs) 0;
  }

  .footer-col a:hover {
    color: white;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-bottom p {
    color: var(--slate);
    font-size: 0.875rem;
    margin: 0;
  }

  .footer-legal {
    display: flex;
    gap: var(--space-lg);
  }

  .footer-legal a {
    color: var(--slate);
    font-size: 0.875rem;
  }

  .footer-legal a:hover {
    color: white;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer-bottom {
      flex-direction: column;
      gap: var(--space-md);
      text-align: center;
    }
  }
</style>
