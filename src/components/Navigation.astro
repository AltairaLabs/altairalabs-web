---
const base = import.meta.env.BASE_URL;

const pillars = [
  {
    label: 'Talk to Customers',
    href: `${base}/solutions/`,
    links: [
      { href: `${base}/solutions/customer-support/`, label: 'Customer Support' },
      { href: `${base}/solutions/sales/`, label: 'Sales' },
      { href: `${base}/solutions/onboarding/`, label: 'Onboarding' },
    ],
  },
  {
    label: 'Build Things',
    href: `${base}/solutions/`,
    links: [
      { href: `${base}/solutions/`, label: 'Coming Soon' },
    ],
  },
  {
    label: 'Make Sense of Things',
    href: `${base}/solutions/`,
    links: [
      { href: `${base}/solutions/`, label: 'Coming Soon' },
    ],
  },
];

const docLinks = [
  { href: 'https://omnia.altairalabs.ai/', label: 'Omnia Docs' },
  { href: 'https://promptkit.altairalabs.ai/', label: 'PromptKit Docs' },
  { href: 'https://promptpack.org/', label: 'PromptPack Docs' },
];
---

<nav class="nav">
  <div class="nav-container">
    <a href="/" class="logo">
      <svg class="logo-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="20" cy="6" r="3" fill="#3B82F6"/>
        <circle cx="8" cy="18" r="2.5" fill="#06B6D4"/>
        <circle cx="32" cy="18" r="2.5" fill="#06B6D4"/>
        <circle cx="12" cy="32" r="2" fill="#8B5CF6"/>
        <circle cx="28" cy="32" r="2" fill="#8B5CF6"/>
        <circle cx="20" cy="20" r="3" fill="#3B82F6"/>
        <line x1="20" y1="9" x2="20" y2="17" stroke="#3B82F6" stroke-width="1.5"/>
        <line x1="10" y1="18" x2="17" y2="20" stroke="#06B6D4" stroke-width="1.5"/>
        <line x1="30" y1="18" x2="23" y2="20" stroke="#06B6D4" stroke-width="1.5"/>
        <line x1="13" y1="31" x2="18" y2="22" stroke="#8B5CF6" stroke-width="1.5"/>
        <line x1="27" y1="31" x2="22" y2="22" stroke="#8B5CF6" stroke-width="1.5"/>
      </svg>
      <span class="logo-text">ALTAIRA<span class="logo-labs">LABS</span></span>
    </a>
    <div class="nav-links">
      <a href={`${base}/#products`}>Products</a>
      <div class="nav-dropdown">
        <a href={`${base}/solutions/`} class="nav-dropdown-trigger">Solutions</a>
        <div class="nav-dropdown-menu">
          <div class="nav-dropdown-menu-panel">
            {pillars.map((pillar) => (
              <>
                <span class="nav-dropdown-heading">{pillar.label}</span>
                {pillar.links.map((item) => (
                  <a href={item.href}>{item.label}</a>
                ))}
              </>
            ))}
          </div>
        </div>
      </div>
      <a href={`${base}/blog/`}>Blog</a>
      <div class="nav-dropdown">
        <a href="#" class="nav-dropdown-trigger">Docs</a>
        <div class="nav-dropdown-menu">
          <div class="nav-dropdown-menu-panel">
            {docLinks.map((item) => (
              <a href={item.href} target="_blank" rel="noopener">{item.label}</a>
            ))}
          </div>
        </div>
      </div>
    </div>
    <div class="nav-actions">
      <a href="https://github.com/AltairaLabs" target="_blank" rel="noopener" class="btn btn-ghost">GitHub</a>
      <a href="https://omnia.altairalabs.ai/getting-started/" target="_blank" rel="noopener" class="btn btn-primary">Get Started</a>
    </div>
    <button class="hamburger" id="hamburger-btn" aria-label="Toggle menu" aria-expanded="false">
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>
  </div>
  <div class="mobile-menu" id="mobile-menu">
    <div class="mobile-menu-inner">
      <a href={`${base}/#products`} class="mobile-link">Products</a>
      <div class="mobile-docs-section">
        <a href={`${base}/solutions/`} class="mobile-docs-label-link">Solutions</a>
        {pillars.map((pillar) => (
          <>
            <span class="mobile-pillar-label">{pillar.label}</span>
            {pillar.links.map((item) => (
              <a href={item.href} class="mobile-link mobile-doc-link">{item.label}</a>
            ))}
          </>
        ))}
      </div>
      <a href={`${base}/blog/`} class="mobile-link">Blog</a>
      <div class="mobile-docs-section">
        <span class="mobile-docs-label">Docs</span>
        {docLinks.map((item) => (
          <a href={item.href} target="_blank" rel="noopener" class="mobile-link mobile-doc-link">{item.label}</a>
        ))}
      </div>
      <div class="mobile-actions">
        <a href="https://github.com/AltairaLabs" target="_blank" rel="noopener" class="btn btn-ghost mobile-btn">GitHub</a>
        <a href="https://omnia.altairalabs.ai/getting-started/" target="_blank" rel="noopener" class="btn btn-primary mobile-btn">Get Started</a>
      </div>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(15, 23, 42, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
  }

  .logo-icon {
    width: 36px;
    height: 36px;
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: white;
  }

  .logo-labs {
    font-weight: 400;
    letter-spacing: 0.2em;
    color: var(--slate);
    margin-left: 4px;
  }

  .nav-links {
    display: flex;
    gap: var(--space-lg);
    align-items: center;
  }

  .nav-links > a {
    color: var(--mist);
    font-weight: 500;
    font-size: 0.9375rem;
  }

  .nav-links > a:hover {
    color: white;
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-trigger {
    color: var(--mist);
    font-weight: 500;
    font-size: 0.9375rem;
    cursor: pointer;
  }

  .nav-dropdown-trigger:hover {
    color: white;
  }

  .nav-dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding-top: 8px;
    min-width: 200px;
    background: transparent;
  }

  .nav-dropdown-menu-panel {
    background: var(--deep-space);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    padding: var(--space-sm) 0;
    box-shadow: var(--shadow-xl);
  }

  .nav-dropdown:hover .nav-dropdown-menu {
    display: block;
  }

  .nav-dropdown-heading {
    display: block;
    padding: var(--space-xs) var(--space-md);
    color: var(--slate);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .nav-dropdown-heading:not(:first-child) {
    margin-top: var(--space-xs);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: var(--space-sm);
  }

  .nav-dropdown-menu-panel a {
    display: block;
    padding: var(--space-sm) var(--space-md);
    color: var(--mist);
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .nav-dropdown-menu-panel a:hover {
    color: white;
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-actions {
    display: flex;
    gap: var(--space-md);
  }

  .nav-actions .btn-ghost {
    color: var(--mist);
  }

  .nav-actions .btn-ghost:hover {
    color: white;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 10;
  }

  .hamburger-bar {
    display: block;
    width: 20px;
    height: 2px;
    background: white;
    border-radius: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .hamburger[aria-expanded="true"] .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger[aria-expanded="true"] .hamburger-bar:nth-child(2) {
    opacity: 0;
  }

  .hamburger[aria-expanded="true"] .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    background: rgba(15, 23, 42, 0.98);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.3s ease;
  }

  .mobile-menu.open {
    max-height: 500px;
  }

  .mobile-menu-inner {
    padding: var(--space-md) var(--space-lg) var(--space-lg);
    display: flex;
    flex-direction: column;
  }

  .mobile-link {
    display: block;
    color: var(--mist);
    font-weight: 500;
    font-size: 0.9375rem;
    padding: 12px 0;
    min-height: 44px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    text-decoration: none;
  }

  .mobile-link:hover {
    color: white;
  }

  .mobile-docs-section {
    padding-top: 8px;
  }

  .mobile-docs-label,
  .mobile-docs-label-link {
    display: block;
    color: var(--slate);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 8px 0 4px;
    text-decoration: none;
  }

  .mobile-docs-label-link:hover {
    color: white;
  }

  .mobile-pillar-label {
    display: block;
    color: var(--altair-blue);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 6px 0 2px var(--space-md);
  }

  .mobile-pillar-label:not(:first-of-type) {
    margin-top: 4px;
  }

  .mobile-doc-link {
    padding-left: var(--space-md);
  }

  .mobile-actions {
    display: flex;
    gap: var(--space-md);
    padding-top: var(--space-md);
    margin-top: var(--space-sm);
  }

  .mobile-btn {
    flex: 1;
    text-align: center;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }

    .nav-actions {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    .mobile-menu {
      display: block;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  hamburger?.addEventListener('click', () => {
    const expanded = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!expanded));
    mobileMenu?.classList.toggle('open');
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger?.setAttribute('aria-expanded', 'false');
      mobileMenu?.classList.remove('open');
    });
  });
</script>
