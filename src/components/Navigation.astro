---
const navItems = [
  { href: '#products', label: 'Products' },
  { href: '#solutions', label: 'Solutions' },
];

const docLinks = [
  { href: 'https://omnia.altairalabs.ai/', label: 'Omnia Docs' },
  { href: 'https://promptkit.altairalabs.ai/', label: 'PromptKit Docs' },
  { href: 'https://promptpack.org/', label: 'PromptPack Docs' },
];
---

<nav class="nav">
  <div class="nav-container">
    <a href="/" class="logo">
      <svg class="logo-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="20" cy="6" r="3" fill="#3B82F6"/>
        <circle cx="8" cy="18" r="2.5" fill="#06B6D4"/>
        <circle cx="32" cy="18" r="2.5" fill="#06B6D4"/>
        <circle cx="12" cy="32" r="2" fill="#8B5CF6"/>
        <circle cx="28" cy="32" r="2" fill="#8B5CF6"/>
        <circle cx="20" cy="20" r="3" fill="#3B82F6"/>
        <line x1="20" y1="9" x2="20" y2="17" stroke="#3B82F6" stroke-width="1.5"/>
        <line x1="10" y1="18" x2="17" y2="20" stroke="#06B6D4" stroke-width="1.5"/>
        <line x1="30" y1="18" x2="23" y2="20" stroke="#06B6D4" stroke-width="1.5"/>
        <line x1="13" y1="31" x2="18" y2="22" stroke="#8B5CF6" stroke-width="1.5"/>
        <line x1="27" y1="31" x2="22" y2="22" stroke="#8B5CF6" stroke-width="1.5"/>
      </svg>
      <span class="logo-text">ALTAIRA<span class="logo-labs">LABS</span></span>
    </a>
    <div class="nav-links">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
      <div class="nav-dropdown">
        <a href="#" class="nav-dropdown-trigger">Docs</a>
        <div class="nav-dropdown-menu">
          {docLinks.map((item) => (
            <a href={item.href} target="_blank" rel="noopener">{item.label}</a>
          ))}
        </div>
      </div>
    </div>
    <div class="nav-actions">
      <a href="https://github.com/AltairaLabs" target="_blank" rel="noopener" class="btn btn-ghost">GitHub</a>
      <a href="https://omnia.altairalabs.ai/getting-started/" target="_blank" rel="noopener" class="btn btn-primary">Get Started</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(15, 23, 42, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
  }

  .logo-icon {
    width: 36px;
    height: 36px;
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: white;
  }

  .logo-labs {
    font-weight: 400;
    letter-spacing: 0.2em;
    color: var(--slate);
    margin-left: 4px;
  }

  .nav-links {
    display: flex;
    gap: var(--space-xl);
    align-items: center;
  }

  .nav-links > a {
    color: var(--mist);
    font-weight: 500;
    font-size: 0.9375rem;
  }

  .nav-links > a:hover {
    color: white;
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-trigger {
    color: var(--mist);
    font-weight: 500;
    font-size: 0.9375rem;
    cursor: pointer;
  }

  .nav-dropdown-trigger:hover {
    color: white;
  }

  .nav-dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-top: 12px;
    background: var(--deep-space);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    padding: var(--space-sm) 0;
    min-width: 180px;
    box-shadow: var(--shadow-xl);
  }

  .nav-dropdown:hover .nav-dropdown-menu {
    display: block;
  }

  .nav-dropdown-menu a {
    display: block;
    padding: var(--space-sm) var(--space-md);
    color: var(--mist);
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .nav-dropdown-menu a:hover {
    color: white;
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-actions {
    display: flex;
    gap: var(--space-md);
  }

  .nav-actions .btn-ghost {
    color: var(--mist);
  }

  .nav-actions .btn-ghost:hover {
    color: white;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }

    .nav-actions .btn-ghost {
      display: none;
    }
  }
</style>
